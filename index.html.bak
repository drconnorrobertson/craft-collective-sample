  <!-- ABOUT / DEREK -->
  <section class="about" aria-labelledby="about-heading">
    <div class="about-image">
      <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=85" alt="Derek Piekarski - award-winning hairstylist and owner of Craft Collective Salon Group Pittsburgh" loading="lazy" />
      <div class="about-image-badge">
        <span class="badge-num">7</span>
        <span class="badge-text">Global Brands<br>Trained</span>
      </div>
    </div>
    <div class="about-content">
      <p class="section-label">Meet Derek Piekarski</p>
      <h2 id="about-heading" class="section-headline">World-class<br>expertise.<br><em>Pittsburgh proud.</em></h2>
      <p class="about-body">Derek Piekarski is one of the most credentialed hairdressers in North America. He built his career training artists for 7 top hair brands, serving on the North America Signature Artist Team for Wella Professionals, and leading technical education for Aveda / Estée Lauder across an entire continent. Now that expertise is available to you in Pittsburgh.</p>
      <div class="about-credentials">
        <span class="credential">Franz Stroher Global Education Master Trainer Award, Wella Professionals (2016)</span>
        <span class="credential">North America Signature Artist, Wella Professionals</span>
        <span class="credential">North America Manager of Technical Capabilities, Aveda / Estée Lauder</span>
        <span class="credential">Featured in Vogue India</span>
        <span class="credential">Celebrity clientele across the US, Europe, South America, India, and Canada</span>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="services" aria-labelledby="services-heading">
    <div class="services-header">
      <div>
        <p class="section-label">What We Do</p>
        <h2 id="services-heading" class="section-headline">Our <em>services</em></h2>
      </div>
      <a href="/hair-services-pittsburgh" class="btn-ghost" style="color:var(--gold);border-color:rgba(184,154,106,0.4)">View All Services</a>
    </div>
    <div class="services-grid">
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">01</p>
        <h3 class="service-name">Balayage</h3>
        <p class="service-desc">Soft, sunlit dimension painted freehand for a natural finish that grows out beautifully and requires less maintenance between visits.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">02</p>
        <h3 class="service-name">Highlights</h3>
        <p class="service-desc">Customized foil placements designed to brighten, blend regrowth, or add contrast with strategic sectioning for lasting dimension.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">03</p>
        <h3 class="service-name">Blonding</h3>
        <p class="service-desc">Full blonding, platinum, lived-in blonde, or bright foils for all hair types. Every blonding service includes custom toning to your ideal shade.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">04</p>
        <h3 class="service-name">Hair Color</h3>
        <p class="service-desc">Full color, root touch-ups, glossing, toning, and complete color transformations that enhance your features while keeping hair healthy.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">05</p>
        <h3 class="service-name">Extensions</h3>
        <p class="service-desc">Multiple extension methods customized to your goals, hair density, and maintenance preferences. Consultations required.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
      <a href="/hair-services-pittsburgh" class="service-card">
        <p class="service-num">06</p>
        <h3 class="service-name">Keratin</h3>
        <p class="service-desc">Smoothing treatments that reduce frizz, improve manageability, and add long-lasting shine for softer, faster-drying hair.</p>
        <span class="service-arrow">Learn more &rarr;</span>
      </a>
    </div>
  </section>

